# template: 始终使用固定模板
# llm: 必须调用 LLM，调用或 JSON 校验失败时任务失败
# auto: 优先调用 LLM，失败时回退固定模板
AI_PLANNER_MODE=auto

# OpenAI-compatible API 配置
AI_PLANNER_BASE_URL=https://api.openai.com/v1
AI_PLANNER_API_KEY=
AI_PLANNER_MODEL=
AI_PLANNER_TIMEOUT=60

# Phase 3 代码增强模型；留空时复用 AI_PLANNER_MODEL
AI_CODEGEN_MODEL=
AI_CODEGEN_TIMEOUT=90
