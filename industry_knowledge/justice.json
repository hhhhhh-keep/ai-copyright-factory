      "table": "case_evidence",
      "question": "是否需要证据管理？",
      "default": false
    },
    {
      "key": "statistics",
      "name": "办案统计",
      "description": "统计案件办理数量、期限和完成情况",
      "pages": ["办案概览", "期限分析"],
      "fields": ["统计日期", "案件总数", "办结数量", "逾期数量", "办结率"],
      "table": "justice_statistics",
      "question": "是否需要办案统计分析？",
      "default": true
    }
