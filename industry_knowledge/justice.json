      "table": "case_dossiers",
      "question": "是否需要电子卷宗管理？",
      "default": true
    },
    {
      "key": "documents",
      "name": "法律文书",
      "description": "管理法律文书模板、制作和归档",
      "pages": ["文书列表", "文书制作", "文书详情"],
      "fields": ["文书编号", "文书类型", "案件编号", "制作人员", "文书状态"],
      "table": "legal_documents",
      "question": "是否需要法律文书管理？",
      "default": true
    },
    {
      "key": "case_flow",
      "name": "案件流转",
      "description": "记录案件在各业务节点之间的流转过程",
      "pages": ["待办案件", "流转记录", "流程跟踪"],
      "fields": ["案件编号", "当前节点", "承办人员", "流转时间", "办理期限"],
      "table": "case_flow_records",
      "question": "是否需要案件流转跟踪？",
      "default": true
    },
    {
      "key": "approvals",
      "name": "案件审批",
      "description": "处理案件审批申请和审批意见",
      "pages": ["待审批列表", "审批处理", "审批记录"],
      "fields": ["审批编号", "案件编号", "申请人员", "审批人员", "审批结果"],
      "table": "case_approvals",
      "question": "是否需要案件审批？",
      "default": true
    },
    {
      "key": "evidence",
      "name": "证据管理",
      "description": "登记证据信息并维护证据流转记录",
      "pages": ["证据列表", "证据登记", "证据流转"],
