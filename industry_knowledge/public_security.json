{
  "key": "public_security",
  "name": "公安",
  "aliases": ["公安", "警务", "涉案", "警情", "布控", "视频巡查", "重点人员"],
  "terms": ["警情", "案件", "涉案车辆", "布控", "预警", "研判"],
